import fs from 'fs';
import { SNES } from './src/SNES.js';
const snes = new SNES();
snes.loadRom(fs.readFileSync('./rom/zelda.sfc'));
let currentFrame = 0;
let oldStep = snes.cpu.step.bind(snes.cpu);
snes.cpu.step = function() {
    if (currentFrame === 836) {
        console.log(`[F836] PB:PC=${snes.cpu.PB.toString(16)}:${snes.cpu.PC.toString(16)}`);
    }
    oldStep();
};
for(let f=0; f<=836; f++){
  currentFrame = f; snes.frame();
}
